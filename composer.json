{
    "name": "eloquent-works/fellowship",
    "description": "Fellowship provides elegant friendship and social connection tools for Laravel applications, including friend requests, blocks, mutual friends, and relationship management.",
    "keywords": [
        "laravel",
        "fellowship-system",
        "fellowship",
        "social",
        "eloquent"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Nicholas English",
            "email": "nenglish443@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/database": "^12.0 || ^13.0",
        "illuminate/events": "^12.0 || ^13.0",
        "illuminate/pagination": "^12.0 || ^13.0",
        "illuminate/support": "^12.0 || ^13.0",
        "illuminate/routing": "^12.0 || ^13.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^10.0 || ^11.0",
        "phpunit/phpunit": "^11.5 || ^12.0",
        "laravel/pint": "^1.0",
        "larastan/larastan": "^3.0",
        "friendsofphp/php-cs-fixer": "^3.95"
    },
    "autoload": {
        "psr-4": {
            "EloquentWorks\\Fellowship\\": "src/"
        }
    },
    "autoload-dev": {
        "files": [
            "tests/helpers.php"
        ],
        "classmap": [
            "tests/Stub_User.php"
        ],
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "EloquentWorks\\Fellowship\\FellowshipServiceProvider"
            ],
            "aliases": {
                "Fellowship": "EloquentWorks\\Fellowship\\Facades\\Fellowship"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "format": "pint",
        "format:test": "pint --test",
        "analyse": "phpstan analyse",
        "test": "phpunit",
        "ci": [
            "@format:test",
            "@analyse",
            "@test"
        ]
    }
}
